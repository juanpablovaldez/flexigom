{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Productos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "categories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::category.category",
      "mappedBy": "products"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "blocks"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "discount_price": {
      "type": "decimal"
    },
    "stock": {
      "type": "integer",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images", "videos"]
    },
    "specifications": {
      "type": "blocks"
    },
    "composition": {
      "type": "enumeration",
      "required": false,
      "enum": ["Espuma de memoria", "Resorte", "Híbrido", "Látex", "Espuma"]
    },
    "measurement": {
      "type": "enumeration",
      "required": false,
      "enum": ["Una plaza", "Dos plazas", "Queen", "King (1.80x2)", "King Size (2x2)"]
    },
    "brand": {
      "type": "enumeration",
      "required": true,
      "enum": ["Flexigom"]
    }
  }
}
